# Puerto en el que corre la API
PORT=5120

# Origen permitido para CORS (frontend)
FRONTEND_ORIGIN=http://localhost:3000

# Mail provider (SMTP)
# Ejemplo usando un servidor SMTP (Mailtrap, Sendinblue SMTP, proveedores de hosting, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=no-reply@your-domain.com

# Email de contacto público
CONTACT_EMAIL=contacto@augreen.cl
# Server
PORT=5120
FRONTEND_ORIGIN=http://localhost:8100

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
FROM_EMAIL=you@yourdomain.com
